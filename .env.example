# -------------------------------------------------
# Domain & Routing
# -------------------------------------------------
DOMAIN=trackit.local
# Frontend public URL (used in emails, redirects)
FRONTEND_HOST=http://localhost:5173

# -------------------------------------------------
# Environment
# -------------------------------------------------
ENVIRONMENT=development
PROJECT_NAME=TrackIT
STACK_NAME=trackit

# -------------------------------------------------
# Backend Security
# -------------------------------------------------
# Generate with: openssl rand -hex 32
SECRET_KEY=generate-a-secure-secret-key-here

FIRST_SUPERUSER=admin@example.com
FIRST_SUPERUSER_PASSWORD=change_this_password

# -------------------------------------------------
# CORS (Development/Production)
# -------------------------------------------------
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# -------------------------------------------------
# PostgreSQL (Docker service)
# -------------------------------------------------
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_DB=trackit_v1
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_here

# -------------------------------------------------
# Redis (Docker service)
# -------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379

# -------------------------------------------------
# Email (SMTP)
# -------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587
EMAILS_FROM_EMAIL=no-reply@example.com

# -------------------------------------------------
# Docker Images (local build)
# -------------------------------------------------
DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
TAG=latest

EMAIL=admin@example.com

# -------------------------------------------------
# Sentry (optional)
# -------------------------------------------------
SENTRY_DSN=

# -------------------------------------------------
# TrackIT Notification Thresholds
# -------------------------------------------------
EXPENSE_ALERT_THRESHOLD=5000
MONTHLY_BUDGET_LIMIT=50000

# -------------------------------------------------
# AWS S3 (optional)
# -------------------------------------------------
S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# -------------------------------------------------
# Adminer / Traefik Basic Auth
# -------------------------------------------------
USERNAME=admin
HASHED_PASSWORD=your_hashed_password_here
